{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "specskills change state",
  "type": "object",
  "required": ["name", "schema", "createdAt", "updatedAt", "artifacts"],
  "properties": {
    "name": {
      "type": "string",
      "pattern": "^[a-z0-9]+(?:-[a-z0-9]+)*$"
    },
    "schema": {
      "type": "string"
    },
    "createdAt": {
      "type": "string",
      "format": "date-time"
    },
    "updatedAt": {
      "type": "string",
      "format": "date-time"
    },
    "artifacts": {
      "type": "object",
      "additionalProperties": {
        "type": "object",
        "required": ["status", "path"],
        "properties": {
          "status": {
            "type": "string",
            "enum": ["done", "ready", "blocked"]
          },
          "path": {
            "type": "string"
          }
        },
        "additionalProperties": false
      }
    }
  },
  "additionalProperties": false
}
